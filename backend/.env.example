# Database - do not commit real credentials
# This matches the default user/password/db created by docker-compose / podman compose.
# If you changed POSTGRES_USER or POSTGRES_PASSWORD in the project root .env, use those here.
DATABASE_URL=postgresql://promptlib:promptlib@localhost:5432/prompt_library

# Mock SSO / session signing - use a long random string in production
SECRET_KEY=change-me-to-a-secure-random-string

# Optional: CORS origins (comma-separated), default allows frontend dev server
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: for "Help me create a prompt" – OpenAI API key (e.g. sk-...)
# OPENAI_API_KEY=

# Copy to .env in the project root when using Docker for the database.
# Used by: docker compose up
# Backend should use the same values in backend/.env for DATABASE_URL.

POSTGRES_USER=promptlib
POSTGRES_PASSWORD=promptlib
POSTGRES_DB=prompt_library

# Backend connection (use this in backend/.env when DB runs in Docker):
# DATABASE_URL=postgresql://promptlib:promptlib@localhost:5432/prompt_library
